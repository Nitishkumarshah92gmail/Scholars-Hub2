# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Drive (for file uploads)
# Option 1: Env vars (recommended for Render / cloud deployment)
GOOGLE_DRIVE_CLIENT_EMAIL=your_service_account_email@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n
# Option 2: JSON key file (local development)
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Server Port
PORT=5000

# YouTube Data API Key (for video/playlist validation)
YOUTUBE_API_KEY=your_youtube_api_key
